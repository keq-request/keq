{
  "type": "module",
  "name": "@keq-request/cli",
  "main": "dist/index.cjs",
  "types": "dist/index.d.cts",
  "bin": {
    "keq": "dist/cli.cjs",
    "@keq-request/cli": "dist/cli.cjs"
  },
  "description": "Transform Swagger/OpenAPI to the function that send request by keq",
  "version": "5.0.0-beta.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keq-request/keq.git"
  },
  "keywords": [
    "keq",
    "cli",
    "command",
    "swagger",
    "openapi",
    "request"
  ],
  "author": "Val.istar.Guo <val.istar.guo@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/keq-request/keq/issues"
  },
  "homepage": "https://keq-request.github.io",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./plugins": {
      "import": {
        "types": "./dist/plugins.d.mts",
        "default": "./dist/plugins.mjs"
      },
      "require": {
        "types": "./dist/plugins.d.cts",
        "default": "./dist/plugins.cjs"
      }
    },
    "./translators": {
      "import": {
        "types": "./dist/translators.d.mts",
        "default": "./dist/translators.mjs"
      },
      "require": {
        "types": "./dist/translators.d.cts",
        "default": "./dist/translators.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "jest",
    "test:update": "jest -u"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.19.39",
    "@types/picomatch": "^4.0.3",
    "@types/ramda": "^0.31.1",
    "@types/swagger2openapi": "^7.0.4",
    "keq": "workspace:*"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "@listr2/prompt-adapter-inquirer": "^3.0.5",
    "@opendoc/openapi-shaking": "^1.5.3",
    "@scalar/openapi-parser": "^0.26.0",
    "@scalar/openapi-types": "^0.8.0",
    "@sinclair/typebox": "^0.34.49",
    "@types/semver": "^7.7.1",
    "@types/validator": "^13.15.10",
    "ajv": "^8.20.0",
    "chalk": "4.1.2",
    "change-case": "5.4.4",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.1",
    "fs-extra": "^11.3.4",
    "inquirer-select-pro": "1.0.0-alpha.9",
    "js-yaml": "^4.1.1",
    "jsonpath-plus": "^10.4.0",
    "jsonpointer": "^5.0.1",
    "listr2": "^9.0.5",
    "picomatch": "^4.0.4",
    "ramda": "^0.32.0",
    "semver": "^7.7.4",
    "swagger-fix": "^1.0.5",
    "tapable": "^2.3.3",
    "ts-custom-error": "^3.3.1",
    "type-fest": "^5.6.0",
    "valid-url": "^1.0.9",
    "validator": "^13.15.35",
    "word-wrap": "^1.2.5"
  },
  "peerDependencies": {
    "keq": "workspace:*"
  },
  "optionalDependencies": {
    "eslint": "^10.2.1"
  }
}
